<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>


<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <VBox layoutX="-2.0" prefHeight="403.0" prefWidth="600.0">
         <children>
            <TableView prefHeight="316.0" prefWidth="600.0">
              <columns>
                <TableColumn fx:id="colId" prefWidth="37.0" text="ID" />
                  <TableColumn fx:id="colCode" prefWidth="70.0" text="CÓDIGO" />
                <TableColumn fx:id="colName" prefWidth="114.0" text="NOMBRE" />
                  <TableColumn fx:id="colDescription" prefWidth="130.0" text="DESCRIPCION" />
                  <TableColumn fx:id="colPrice" prefWidth="64.0" text="PRECIO" />
                  <TableColumn fx:id="colCategory" prefWidth="97.0" text="CATEGORÍA" />
                  <TableColumn fx:id="colStock" prefWidth="87.0" text="STOCK" />
              </columns>
            </TableView>
            <HBox prefHeight="112.0" prefWidth="600.0">
               <children>
                  <Button mnemonicParsing="false" text="Añadir" />
                  <Button mnemonicParsing="false" text="Editar" />
                  <Button mnemonicParsing="false" text="Buscar" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
